{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "scripts/check-codecov-config.d.mts",
    "scripts/check-coverage-policy.d.mts",
    "scripts/check-renovate-config.d.mts",
    "scripts/check-security-tooling.d.mts",
    "scripts/check-toolchain.d.mts",
    "scripts/coverage-policy.d.mts",
    "scripts/dispatch-renovate-checks.d.mts",
    "scripts/release-state-core.d.mts",
    "scripts/report-coverage.d.mts",
    "scripts/run-pnpm.d.mts",
    "scripts/sync-security-policy.d.mts",
    "tests/performance/k6/*.js"
  ],
  "ignoreDependencies": [
    "search-insights",
    "jscpd",
    "@anthropic-ai/sdk",
    "langchain",
    "llamaindex",
    "@arethetypeswrong/packages",
    "@arethetypeswrong/cli",
    "publint"
  ],
  "ignoreBinaries": ["gh", "playwright", "view", "where.exe", "semgrep", "pre-commit"],
  "workspaces": {
    "packages/registry": {
      "entry": ["src/index.ts", "src/bin/start.ts"]
    }
  }
}
