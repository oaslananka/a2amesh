{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:monorepos",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Istanbul",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency Dashboard",
  "labels": ["area:deps", "type:task"],
  "automerge": false,
  "prHourlyLimit": 3,
  "prConcurrentLimit": 6,
  "branchConcurrentLimit": 6,
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "prCreation": "not-pending",
  "rebaseWhen": "conflicted",
  "postUpdateOptions": ["pnpmDedupe"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 7am on the first day of the month"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/security\\.yml$/"],
      "matchStrings": ["GITLEAKS_VERSION:\\\\s*['\\\"]?(?<currentValue>[^'\\\"\\\\s]+)['\\\"]?"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "gitleaks/gitleaks"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/security\\.yml$/"],
      "matchStrings": ["ACTIONLINT_VERSION:\\\\s*['\\\"]?(?<currentValue>[^'\\\"\\\\s]+)['\\\"]?"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "rhysd/actionlint"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/security\\.yml$/"],
      "matchStrings": ["OSV_SCANNER_VERSION:\\\\s*['\\\"]?(?<currentValue>[^'\\\"\\\\s]+)['\\\"]?"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "google/osv-scanner",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/security\\.yml$/"],
      "matchStrings": ["ZIZMOR_VERSION:\\\\s*['\\\"]?(?<currentValue>[^'\\\"\\\\s]+)['\\\"]?"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "zizmorcore/zizmor"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^tools\\/runtime-versions\\.json$/"],
      "matchStrings": ["\"pnpm\"\\s*:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "npm",
      "depNameTemplate": "pnpm"
    }
  ],
  "packageRules": [
    {
      "description": "Keep routine upgrades review-required.",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false
    },
    {
      "description": "Require explicit approval for breaking upgrades.",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "automerge": false,
      "labels": ["priority:P1", "type:task", "area:deps"]
    },
    {
      "description": "Workspace-owned linked packages are versioned only by Release Please.",
      "matchPackageNames": ["/^@a2amesh\\//"],
      "enabled": false
    },
    {
      "groupName": "vitest monorepo",
      "matchPackageNames": ["vitest", "/^@vitest\\//"]
    },
    {
      "groupName": "hono monorepo",
      "matchPackageNames": ["hono", "@hono/node-server"]
    },
    {
      "groupName": "opentelemetry",
      "matchPackageNames": ["/^@opentelemetry\\//"]
    },
    {
      "description": "Keep registry UI dependency updates visible as one workspace-scoped PR.",
      "groupName": "registry UI dependencies",
      "matchFileNames": ["apps/registry-ui/**"]
    },
    {
      "description": "Keep docs site dependency updates visible as one workspace-scoped PR.",
      "groupName": "docs site dependencies",
      "matchFileNames": ["docs-site/**"]
    },
    {
      "description": "Keep externally executed automation immutable and review-required.",
      "matchManagers": ["github-actions", "dockerfile", "docker-compose"],
      "pinDigests": true,
      "automerge": false,
      "labels": ["area:ci", "area:deps", "type:task"]
    },
    {
      "description": "Update pinned security tools together for one evidence review.",
      "groupName": "security toolchain",
      "matchManagers": ["custom.regex"],
      "automerge": false,
      "labels": ["area:security", "area:deps", "type:task"]
    },
    {
      "description": "Update the pnpm source of truth and regenerate every governed runtime mirror.",
      "groupName": "pnpm toolchain",
      "matchPackageNames": ["pnpm"],
      "automerge": false,
      "labels": ["area:deps", "area:dx", "type:task"],
      "postUpgradeTasks": {
        "commands": ["node scripts/check-runtime-versions.mjs --write"],
        "fileFilters": ["**/*"],
        "executionMode": "branch"
      }
    },
    {
      "description": "Repository-owned unpublished images are released by the project, not Renovate.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^ghcr\\.io\\/oaslananka\\/a2amesh-/"],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["priority:P1", "type:security", "area:deps"]
  },
  "osvVulnerabilityAlerts": true,
  "baseBranchPatterns": ["main"]
}
