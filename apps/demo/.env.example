# LLM providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Registry connection and caller context
REGISTRY_URL=http://localhost:3099
REGISTRY_TOKEN=
REGISTRY_TENANT_ID=
REGISTRY_PRINCIPAL_ID=runtime-demo
REGISTRY_ALLOWED_HOSTNAMES=localhost
RUN_EMBEDDED_REGISTRY=true
ALLOW_PRIVATE_NETWORKS=false

# Agent ports
PORT_RESEARCHER=3001
PORT_WRITER=3002
PORT_ORCHESTRATOR=3003

# URLs advertised through the registry
RESEARCHER_URL=http://localhost:3001
WRITER_URL=http://localhost:3002
ORCHESTRATOR_URL=http://localhost:3003

# Pod-local targets used by the orchestrator
RESEARCHER_INTERNAL_URL=http://localhost:3001
WRITER_INTERNAL_URL=http://localhost:3002

# Optional OTLP telemetry
A2A_TELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=a2amesh-demo
OTEL_TRACES_SAMPLER_ARG=0.1
