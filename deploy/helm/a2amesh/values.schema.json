{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "A2A Mesh chart values",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "serviceAccount",
    "telemetry",
    "registry",
    "runtime",
    "ingress",
    "networkPolicy",
    "smokeTest"
  ],
  "properties": {
    "nameOverride": { "type": "string", "maxLength": 63 },
    "fullnameOverride": { "type": "string", "maxLength": 63 },
    "commonLabels": { "$ref": "#/definitions/stringMap" },
    "commonAnnotations": { "$ref": "#/definitions/stringMap" },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string", "minLength": 1 } },
        "additionalProperties": false
      }
    },
    "deploymentEnvironment": { "type": "string", "minLength": 1 },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "create",
        "annotations",
        "automountServiceAccountToken",
        "runtimeName",
        "registryName"
      ],
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "$ref": "#/definitions/stringMap" },
        "automountServiceAccountToken": { "type": "boolean" },
        "runtimeName": { "type": "string" },
        "registryName": { "type": "string" }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "endpoint", "traceSampleRatio", "metricExportIntervalMs"],
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": { "type": "string" },
        "traceSampleRatio": { "type": "number", "minimum": 0, "maximum": 1 },
        "metricExportIntervalMs": { "type": "integer", "minimum": 1000 }
      }
    },
    "registry": { "$ref": "#/definitions/registry" },
    "runtime": { "$ref": "#/definitions/runtime" },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry", "runtime"],
      "properties": {
        "registry": { "$ref": "#/definitions/ingress" },
        "runtime": {
          "allOf": [
            { "$ref": "#/definitions/ingress" },
            {
              "type": "object",
              "properties": {
                "acknowledgeUnauthenticatedEndpoint": { "type": "boolean" }
              }
            }
          ]
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "registry", "runtime"],
      "properties": {
        "enabled": { "type": "boolean" },
        "registry": { "$ref": "#/definitions/networkPolicyComponent" },
        "runtime": { "$ref": "#/definitions/networkPolicyComponent" }
      }
    },
    "smokeTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "image", "resources", "timeoutSeconds"],
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/definitions/image" },
        "resources": { "$ref": "#/definitions/resources" },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 900 }
      }
    }
  },
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[a-f0-9]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "periodSeconds", "timeoutSeconds", "failureThreshold"],
      "properties": {
        "enabled": { "type": "boolean" },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "limits"],
      "properties": {
        "requests": { "$ref": "#/definitions/resourceMap" },
        "limits": { "$ref": "#/definitions/resourceMap" }
      }
    },
    "resourceMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu": { "type": ["string", "number"] },
        "memory": { "type": "string" },
        "ephemeral-storage": { "type": "string" }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage",
        "targetMemoryUtilizationPercentage"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "targetMemoryUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "allowEphemeralReplicas": { "type": "boolean" }
      }
    },
    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "minAvailable", "maxUnavailable"],
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"], "minimum": 0 },
        "maxUnavailable": { "type": ["integer", "string", "null"], "minimum": 0 }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "replicaCount",
        "revisionHistoryLimit",
        "image",
        "service",
        "auth",
        "cors",
        "outboundPolicy",
        "storage",
        "persistence",
        "podAnnotations",
        "podLabels",
        "podSecurityContext",
        "containerSecurityContext",
        "resources",
        "startupProbe",
        "readinessProbe",
        "livenessProbe",
        "autoscaling",
        "pdb",
        "nodeSelector",
        "tolerations",
        "affinity",
        "topologySpreadConstraints",
        "priorityClassName",
        "terminationGracePeriodSeconds",
        "extraEnv",
        "extraEnvFrom",
        "extraVolumes",
        "extraVolumeMounts"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "image": { "$ref": "#/definitions/image" },
        "service": { "$ref": "#/definitions/registryService" },
        "auth": { "$ref": "#/definitions/registryAuth" },
        "cors": { "$ref": "#/definitions/cors" },
        "outboundPolicy": { "$ref": "#/definitions/outboundPolicy" },
        "storage": { "$ref": "#/definitions/storage" },
        "persistence": { "$ref": "#/definitions/persistence" },
        "podAnnotations": { "$ref": "#/definitions/stringMap" },
        "podLabels": { "$ref": "#/definitions/stringMap" },
        "podSecurityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "resources": { "$ref": "#/definitions/resources" },
        "startupProbe": { "$ref": "#/definitions/probe" },
        "readinessProbe": { "$ref": "#/definitions/probe" },
        "livenessProbe": { "$ref": "#/definitions/probe" },
        "autoscaling": {
          "allOf": [
            { "$ref": "#/definitions/autoscaling" },
            {
              "type": "object",
              "required": ["allowEphemeralReplicas"],
              "properties": { "allowEphemeralReplicas": { "type": "boolean" } }
            }
          ]
        },
        "pdb": { "$ref": "#/definitions/pdb" },
        "nodeSelector": { "$ref": "#/definitions/stringMap" },
        "tolerations": { "type": "array", "items": { "type": "object" } },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": { "type": "array", "items": { "type": "object" } },
        "priorityClassName": { "type": "string" },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 1 },
        "extraEnv": { "type": "array", "items": { "type": "object" } },
        "extraEnvFrom": { "type": "array", "items": { "type": "object" } },
        "extraVolumes": { "type": "array", "items": { "type": "object" } },
        "extraVolumeMounts": { "type": "array", "items": { "type": "object" } }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "replicaCount",
        "revisionHistoryLimit",
        "image",
        "service",
        "providerSecrets",
        "registry",
        "outboundPolicy",
        "podAnnotations",
        "podLabels",
        "podSecurityContext",
        "containerSecurityContext",
        "resources",
        "startupProbe",
        "readinessProbe",
        "livenessProbe",
        "autoscaling",
        "pdb",
        "nodeSelector",
        "tolerations",
        "affinity",
        "topologySpreadConstraints",
        "priorityClassName",
        "terminationGracePeriodSeconds",
        "extraEnv",
        "extraEnvFrom",
        "extraVolumes",
        "extraVolumeMounts"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "image": { "$ref": "#/definitions/image" },
        "service": { "$ref": "#/definitions/runtimeService" },
        "providerSecrets": { "$ref": "#/definitions/providerSecrets" },
        "registry": { "$ref": "#/definitions/runtimeRegistry" },
        "outboundPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowPrivateNetworks"],
          "properties": { "allowPrivateNetworks": { "type": "boolean" } }
        },
        "podAnnotations": { "$ref": "#/definitions/stringMap" },
        "podLabels": { "$ref": "#/definitions/stringMap" },
        "podSecurityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "resources": { "$ref": "#/definitions/resources" },
        "startupProbe": { "$ref": "#/definitions/probe" },
        "readinessProbe": { "$ref": "#/definitions/probe" },
        "livenessProbe": { "$ref": "#/definitions/probe" },
        "autoscaling": { "$ref": "#/definitions/autoscaling" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "nodeSelector": { "$ref": "#/definitions/stringMap" },
        "tolerations": { "type": "array", "items": { "type": "object" } },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": { "type": "array", "items": { "type": "object" } },
        "priorityClassName": { "type": "string" },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 1 },
        "extraEnv": { "type": "array", "items": { "type": "object" } },
        "extraEnvFrom": { "type": "array", "items": { "type": "object" } },
        "extraVolumes": { "type": "array", "items": { "type": "object" } },
        "extraVolumeMounts": { "type": "array", "items": { "type": "object" } }
      }
    },
    "registryService": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "port", "annotations", "clusterIP"],
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "$ref": "#/definitions/stringMap" },
        "clusterIP": { "type": "string" }
      }
    },
    "runtimeService": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "annotations", "clusterIP", "ports"],
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "annotations": { "$ref": "#/definitions/stringMap" },
        "clusterIP": { "type": "string" },
        "ports": {
          "type": "object",
          "additionalProperties": false,
          "required": ["researcher", "writer", "orchestrator"],
          "properties": {
            "researcher": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "writer": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "orchestrator": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        }
      }
    },
    "registryAuth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["require", "createSecret", "existingSecret", "secretKey", "token", "oidc"],
      "properties": {
        "require": { "type": "boolean" },
        "createSecret": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "secretKey": { "type": "string", "minLength": 1 },
        "token": { "type": "string" },
        "oidc": { "$ref": "#/definitions/oidc" }
      }
    },
    "oidc": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "discoveryUrl",
        "jwksUri",
        "issuer",
        "audiences",
        "algorithms",
        "allowedHostnames",
        "allowPrivateNetworks",
        "allowLocalhost"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "discoveryUrl": { "type": "string" },
        "jwksUri": { "type": "string" },
        "issuer": { "type": "string" },
        "audiences": { "type": "array", "items": { "type": "string" } },
        "algorithms": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "allowedHostnames": { "type": "array", "items": { "type": "string" } },
        "allowPrivateNetworks": { "type": "boolean" },
        "allowLocalhost": { "type": "boolean" }
      }
    },
    "cors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedOrigins", "requireOrigin"],
      "properties": {
        "allowedOrigins": { "type": "array", "items": { "type": "string" } },
        "requireOrigin": { "type": "boolean" }
      }
    },
    "outboundPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowLocalhost",
        "allowPrivateNetworks",
        "allowUnresolvedHostnames",
        "allowedHostnames"
      ],
      "properties": {
        "allowLocalhost": { "type": "boolean" },
        "allowPrivateNetworks": { "type": "boolean" },
        "allowUnresolvedHostnames": { "type": "boolean" },
        "allowedHostnames": { "type": "array", "items": { "type": "string" } }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "sqlitePath", "trustLog", "distributedPollingLeases"],
      "properties": {
        "backend": { "type": "string", "enum": ["memory", "sqlite"] },
        "sqlitePath": { "type": "string", "minLength": 1 },
        "trustLog": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "path"],
          "properties": {
            "enabled": { "type": "boolean" },
            "path": { "type": "string", "minLength": 1 }
          }
        },
        "distributedPollingLeases": { "type": "boolean" }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "storageClass", "accessModes", "size", "annotations", "selector"],
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"]
          }
        },
        "size": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "annotations": { "$ref": "#/definitions/stringMap" },
        "selector": { "type": "object" }
      }
    },
    "providerSecrets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createSecret",
        "existingSecret",
        "openAIKeyKey",
        "anthropicKeyKey",
        "openAIKey",
        "anthropicKey"
      ],
      "properties": {
        "createSecret": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "openAIKeyKey": { "type": "string", "minLength": 1 },
        "anthropicKeyKey": { "type": "string", "minLength": 1 },
        "openAIKey": { "type": "string" },
        "anthropicKey": { "type": "string" }
      }
    },
    "runtimeRegistry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "useChartAuthSecret",
        "existingAuthSecret",
        "authSecretKey",
        "tenantId",
        "principalId",
        "allowedHostnames"
      ],
      "properties": {
        "url": { "type": "string" },
        "useChartAuthSecret": { "type": "boolean" },
        "existingAuthSecret": { "type": "string" },
        "authSecretKey": { "type": "string", "minLength": 1 },
        "tenantId": { "type": "string", "minLength": 1 },
        "principalId": { "type": "string", "minLength": 1 },
        "allowedHostnames": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "className", "annotations", "hosts", "tls", "allowInsecureHttp"],
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "$ref": "#/definitions/stringMap" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["host", "paths"],
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path", "pathType"],
                  "properties": {
                    "path": { "type": "string", "pattern": "^/" },
                    "pathType": {
                      "type": "string",
                      "enum": ["Prefix", "Exact", "ImplementationSpecific"]
                    }
                  }
                }
              }
            }
          }
        },
        "tls": { "type": "array", "items": { "type": "object" } },
        "allowInsecureHttp": { "type": "boolean" },
        "acknowledgeUnauthenticatedEndpoint": { "type": "boolean" }
      }
    },
    "networkPolicyComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowInternetEgress", "extraIngress", "extraEgress"],
      "properties": {
        "allowInternetEgress": { "type": "boolean" },
        "extraIngress": { "type": "array", "items": { "type": "object" } },
        "extraEgress": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
